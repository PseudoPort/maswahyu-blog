---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="id">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			* {
				box-sizing: border-box;
			}
			
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				margin: 0;
				padding: 0;
				background: linear-gradient(135deg, #fffbf5 0%, #fff5eb 100%);
				color: #1a1a1a;
				font-size: 18px;
				line-height: 1.75;
				-webkit-font-smoothing: antialiased;
			}
			
			article {
				max-width: 720px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}
			
			.hero-image {
				width: 100%;
				margin-bottom: 1.5rem;
			}
			
			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
				margin: 0;
				border-radius: 12px;
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
			}
			
			.prose {
				color: #333;
			}
			
			.title {
				margin-bottom: 1.5rem;
				padding: 1rem 0;
			}
			
			.title h1 {
				margin: 0 0 0.75rem;
				font-size: 1.75rem;
				line-height: 1.3;
				color: #1a1a1a;
				font-weight: 700;
			}
			
			.date {
				margin: 0;
				color: #888;
				font-size: 0.9rem;
			}
			
			.last-updated-on {
				font-style: italic;
				display: block;
				margin-top: 0.25rem;
			}
			
			hr {
				border: none;
				border-top: 1px solid #eee;
				margin: 1rem 0 0;
			}
			
			/* Typography */
			.prose h2 {
				font-size: 1.5rem;
				margin: 2rem 0 1rem;
				color: #1a1a1a;
				font-weight: 600;
			}
			
			.prose h3 {
				font-size: 1.25rem;
				margin: 1.5rem 0 0.75rem;
				color: #1a1a1a;
				font-weight: 600;
			}
			
			.prose p {
				margin: 0 0 1.25rem;
			}
			
			.prose a {
				color: #ea580c;
				text-decoration: underline;
				text-underline-offset: 2px;
			}
			
			.prose a:hover {
				color: #c2410c;
			}
			
			.prose ul, .prose ol {
				margin: 0 0 1.25rem 1.5rem;
			}
			
			.prose li {
				margin-bottom: 0.5rem;
			}
			
			.prose code {
				padding: 2px 6px;
				background: #f5f5f5;
				border-radius: 4px;
				font-size: 0.9em;
				color: #c2410c;
			}
			
			.prose pre {
				padding: 1.25rem;
				border-radius: 8px;
				overflow-x: auto;
				margin: 1.5rem 0;
				background: #1a1a1a;
				color: #f5f5f5;
			}
			
			.prose pre code {
				padding: 0;
				background: none;
				color: inherit;
			}
			
			.prose blockquote {
				border-left: 4px solid #ea580c;
				padding: 0 0 0 1.25rem;
				margin: 1.5rem 0;
				font-style: italic;
				color: #666;
			}
			
			.prose img {
				max-width: 100%;
				height: auto;
				border-radius: 8px;
				margin: 1.5rem 0;
			}
			
			.prose strong {
				color: #1a1a1a;
				font-weight: 600;
			}
			
			/* Mobile */
			@media (max-width: 640px) {
				body {
					font-size: 16px;
				}
				article {
					padding: 0 1rem;
				}
				.hero-image {
					margin-left: -1rem;
					margin-right: -1rem;
					width: calc(100% + 2rem);
				}
				.hero-image img {
					border-radius: 0;
				}
				.title h1 {
					font-size: 1.5rem;
				}
				.prose h2 {
					font-size: 1.35rem;
				}
				.prose h3 {
					font-size: 1.15rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img src={heroImage.src || heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<p class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="last-updated-on">
									Updated on <FormattedDate date={updatedDate} />
								</span>
							)}
						</p>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
