---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1rem;
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.1rem;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #1a1a1a;
		font-weight: 700;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1000px;
		margin: 0 auto;
	}
	nav h2 a {
		padding: 0.875rem 0;
		display: block;
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
	}
	nav a {
		padding: 0.875rem 0.75rem;
		color: #444;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: all 0.2s;
	}
	nav a:hover {
		color: #ea580c;
	}
	nav a.active {
		color: #ea580c;
		border-bottom-color: #ea580c;
	}
	
	/* Mobile */
	@media (max-width: 480px) {
		header {
			padding: 0 0.75rem;
		}
		h2 {
			font-size: 1rem;
		}
		nav a {
			padding: 0.875rem 0.5rem;
			font-size: 0.9rem;
		}
	}
	
	@media (max-width: 360px) {
		nav a {
			padding: 0.75rem 0.35rem;
			font-size: 0.85rem;
		}
	}
</style>
