---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			* {
				box-sizing: border-box;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				margin: 0;
				background: linear-gradient(135deg, #fffbf5 0%, #fff5eb 100%);
				color: #1a1a1a;
				font-size: 18px;
				line-height: 1.7;
				-webkit-font-smoothing: antialiased;
			}
			main {
				max-width: 1000px;
				margin: 0 auto;
				padding: 2rem 1.5rem;
			}
			.page-title {
				font-size: 1.75rem;
				font-weight: 700;
				margin: 0 0 2rem;
				color: #1a1a1a;
			}
			.posts {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-card {
				background: white;
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 2px 8px rgba(0,0,0,0.06);
				transition: all 0.2s;
			}
			.post-card:hover {
				box-shadow: 0 8px 24px rgba(0,0,0,0.1);
				transform: translateY(-2px);
			}
			.post-card a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.post-image {
				width: 100%;
				height: 180px;
				overflow: hidden;
				background: #f5f5f5;
			}
			.post-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.post-content {
				padding: 1.25rem;
			}
			.post-title {
				margin: 0 0 0.5rem;
				font-size: 1.1rem;
				font-weight: 600;
				color: #1a1a1a;
				line-height: 1.4;
			}
			.post-date {
				margin: 0;
				font-size: 0.875rem;
				color: #888;
			}
			.empty-state {
				text-align: center;
				padding: 3rem;
				color: #888;
			}
			
			/* Mobile */
			@media (max-width: 640px) {
				main {
					padding: 1.5rem 1rem;
				}
				.page-title {
					font-size: 1.5rem;
					margin-bottom: 1.5rem;
				}
				.posts {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.post-image {
					height: 160px;
				}
				.post-content {
					padding: 1rem;
				}
				.post-title {
					font-size: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">Blog</h1>
			
			{posts.length === 0 ? (
				<div class="empty-state">
					<p>Belum ada artikel. Segera hadir!</p>
				</div>
			) : (
				<ul class="posts">
					{posts.map((post) => (
						<li class="post-card">
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<div class="post-image">
										<img 
											src={post.data.heroImage.src || post.data.heroImage} 
											alt="" 
											loading="lazy"
										/>
									</div>
								)}
								<div class="post-content">
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
