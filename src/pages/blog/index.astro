---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description="Artikel tentang AI, automation, dan digital marketing untuk bisnis UKM Indonesia" />
		<style>
			/* Reset & base */
			* {
				box-sizing: border-box;
			}
			
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 1rem;
			}
			
			/* Grid layout for blog posts */
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			
			/* Featured post (first/latest) */
			.post-card.featured {
				grid-column: 1 / -1;
				display: grid;
				grid-template-columns: 1.2fr 1fr;
				gap: 1.5rem;
				align-items: center;
				background: linear-gradient(135deg, #fffbf5 0%, #fff 100%);
				padding: 1.5rem;
				border-radius: 16px;
				margin-bottom: 1rem;
			}
			
			.post-card.featured .post-image img {
				width: 100%;
				height: auto;
				border-radius: 12px;
				box-shadow: 0 4px 16px rgba(234, 88, 12, 0.15);
			}
			
			.post-card.featured .post-content {
				padding: 0.5rem;
			}
			
			.post-card.featured .post-title {
				font-size: 1.75rem;
				line-height: 1.3;
			}
			
			/* Regular post cards */
			.post-card {
				background: #fff;
				border-radius: 12px;
				overflow: hidden;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			
			.post-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 24px rgba(0,0,0,0.1);
			}
			
			.post-card a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			
			.post-image img {
				width: 100%;
				height: 200px;
				object-fit: cover;
				transition: transform 0.3s ease;
			}
			
			.post-card:hover .post-image img {
				transform: scale(1.05);
			}
			
			.post-image {
				overflow: hidden;
			}
			
			.post-content {
				padding: 1.25rem;
			}
			
			.post-title {
				font-size: 1.25rem;
				font-weight: 700;
				color: #1a1a1a;
				margin: 0 0 0.5rem;
				line-height: 1.4;
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
			}
			
			.post-card:hover .post-title {
				color: #ea580c;
			}
			
			.post-date {
				font-size: 0.875rem;
				color: #666;
				margin: 0;
			}
			
			/* Empty state */
			.empty-state {
				text-align: center;
				padding: 3rem;
				color: #666;
			}
			
			/* Responsive */
			@media (max-width: 768px) {
				.post-card.featured {
					grid-template-columns: 1fr;
					padding: 1rem;
				}
				
				.post-card.featured .post-title {
					font-size: 1.4rem;
				}
				
				.posts-grid {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}
				
				.post-image img {
					height: 180px;
				}
				
				.post-title {
					font-size: 1.1rem;
				}
			}
			
			@media (max-width: 480px) {
				main {
					padding: 0.75rem;
				}
				
				.post-card.featured .post-title {
					font-size: 1.25rem;
				}
				
				.post-content {
					padding: 1rem;
				}
				
				.post-image img {
					height: 160px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				{posts.length === 0 ? (
					<div class="empty-state">
						<p>Belum ada artikel. Segera hadir!</p>
					</div>
				) : (
					<ul class="posts-grid">
						{posts.map((post, index) => (
							<li class={`post-card ${index === 0 ? 'featured' : ''}`}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<div class="post-image">
											<img 
												src={post.data.heroImage.src || post.data.heroImage} 
												alt="" 
												loading={index === 0 ? "eager" : "lazy"}
											/>
										</div>
									)}
									<div class="post-content">
										<h2 class="post-title">{post.data.title}</h2>
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
